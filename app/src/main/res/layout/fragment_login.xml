<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <!-- Header dengan gradasi + wave (Mirip Register) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="220dp">

        <!-- Background gradasi biru -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@drawable/bg_gradient_top"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="70dp"
            android:paddingBottom="28dp"
            android:gravity="top"
            tools:ignore="RtlSymmetry">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/halo_wave"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="6dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Masuk Akun"
                android:textColor="#FFFFFF"
                android:textSize="40sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Senang melihatmu kembali🏃🏻‍♂️‍➡️"
                android:textSize="16sp"
                android:textColor="#E0F4FF" />

        </LinearLayout>

        <!-- Wave di bawah header -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_gravity="bottom"
            android:scaleType="fitXY"
            android:src="@drawable/wave_header"
            android:contentDescription="@null" />

    </FrameLayout>

    <!-- Form area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <!-- Label Email -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/email_label"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold" />

            <!-- Input Email -->
            <EditText
                android:id="@+id/username"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="18dp"
                android:background="@drawable/bg_input"
                android:hint="@string/masukkan_email_anda"
                android:inputType="textEmailAddress"
                android:lines="1"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#0F172A"
                android:textColorHint="#CBD5E1"
                android:textSize="14sp"
                android:importantForAutofill="no" />

            <!-- Label Password -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/password_label"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold" />

            <!-- Input Password -->
            <EditText
                android:id="@+id/password"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_input"
                android:hint="@string/min_6_karakter"
                android:inputType="textPassword"
                android:lines="1"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#0F172A"
                android:textColorHint="#CBD5E1"
                android:textSize="14sp"
                android:importantForAutofill="no" />

            <!-- Tombol Login -->
            <Button
                android:id="@+id/login"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="18dp"
                android:backgroundTint="#5BB8E8"
                android:stateListAnimator="@null"
                android:text="Sign In"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/loading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone" />

            <!-- Register link -->
            <TextView
                android:id="@+id/tv_register"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:padding="8dp"
                android:text="Belum punya akun? Daftar dulu"
                android:textSize="13sp"
                android:textColor="#94A3B8"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
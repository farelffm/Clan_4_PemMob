<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical"
    tools:context=".CatatLari_Fragment">

    <!-- Header dengan gradasi + wave (Sesuai Tema Login/Regis) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="220dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@drawable/bg_gradient_top"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="70dp"
            android:paddingBottom="28dp"
            android:gravity="top">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ayo Catat!"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Share Your Journey"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold" />

        </LinearLayout>

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_gravity="bottom"
            android:scaleType="fitXY"
            android:src="@drawable/wave_header"
            android:contentDescription="@null" />
    </FrameLayout>

    <!-- Form Area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <!-- Tanggal -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/tanggal"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etTanggal"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="18dp"
                android:background="@drawable/bg_input"
                android:hint="@string/tanggal"
                android:inputType="none"
                android:focusable="true"
                android:clickable="true"
                android:cursorVisible="false"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#0F172A"
                android:textColorHint="#CBD5E1"
                android:textSize="14sp" />

            <!-- Jarak Lari -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/jarak_lari"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etJarak"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="18dp"
                android:background="@drawable/bg_input"
                android:hint="Masukkan jarak (km)"
                android:inputType="numberDecimal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#0F172A"
                android:textColorHint="#CBD5E1"
                android:textSize="14sp" />

            <!-- Durasi -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/durasi"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etDurasi"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_input"
                android:hint="@string/durasi"
                android:inputType="none"
                android:focusable="true"
                android:clickable="true"
                android:cursorVisible="false"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#0F172A"
                android:textColorHint="#CBD5E1"
                android:textSize="14sp" />

            <!-- Tombol Simpan -->
            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:backgroundTint="#5BB8E8"
                android:stateListAnimator="@null"
                android:text="@string/save_journey"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
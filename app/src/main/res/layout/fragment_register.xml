<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical"
    tools:ignore="HardcodedText,SmallSp,TouchTargetSizeCheck,VisualLintErrors,ContentDescription,SpeakableTextPresentCheck,TextContrastCheck,DuplicateSpeakableAction,ImageContrastCheck,SelectableText,MotionLayoutMissingId,LabelFor,RtlHardcoded,RtlSymmetry,RtlEnabled,UseCompoundDrawables,Autofill,MissingConstraints,InefficientWeight">

    <!-- Header dengan gradasi + wave -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="220dp">

        <!-- Background gradasi biru -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@drawable/bg_gradient_top"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="70dp"
            android:paddingBottom="28dp"
            android:gravity="top">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👋 Halo!"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="6dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Buat Akun Baru"
                android:textColor="#FFFFFF"
                android:textSize="40sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ayo mulai lari bareng kita🏃🏻‍♂️‍➡️ "
                android:textSize="16sp"
                android:textColor="#E0F4FF" />

        </LinearLayout>

        <!-- Wave di bawah header -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_gravity="bottom"
            android:scaleType="fitXY"
            android:src="@drawable/wave_header" />

    </FrameLayout>

    <!-- Form area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <!-- Label Nama -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="NAMA"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold" />

            <!-- Input Nama -->
            <EditText
                android:id="@+id/edt_nama"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="18dp"
                android:background="@drawable/bg_input"
                android:hint="Masukan Nama Anda"
                android:inputType="textPersonName"
                android:lines="1"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#0F172A"
                android:textColorHint="#CBD5E1"
                android:textSize="14sp" />

            <!-- Label Email -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="EMAIL"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold" />

            <!-- Input Email -->
            <EditText
                android:id="@+id/edt_email"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="18dp"
                android:background="@drawable/bg_input"
                android:hint="Masukan Email Anda"
                android:inputType="textEmailAddress"
                android:lines="1"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#0F172A"
                android:textColorHint="#CBD5E1"
                android:textSize="14sp" />

            <!-- Label Password -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="PASSWORD"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold" />

            <!-- Input Password -->
            <EditText
                android:id="@+id/edt_password"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_input"
                android:hint="Min. 6 karakter"
                android:inputType="textPassword"
                android:lines="1"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#0F172A"
                android:textColorHint="#CBD5E1"
                android:textSize="14sp" />

            <!-- Tombol Sign Up -->
            <Button
                android:id="@+id/btn_sign_up"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="18dp"
                android:backgroundTint="#5BB8E8"
                android:stateListAnimator="@null"
                android:text="Sign Up"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Login -->
            <TextView
                android:id="@+id/tv_login"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:padding="8dp"
                android:text="Udah punya akun? Login aja"
                android:textSize="13sp"
                android:textColor="#94A3B8"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>